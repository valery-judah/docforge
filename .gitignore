src/doc_forge/artifacts/**/*.py[cod]
tests/artifacts/**/__pycache__/
tests/artifacts/**/*.py[cod]
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyright/
.hypothesis/
.tox/
.nox/
.cache/
.tmp_docker_config/
.tmp_uv_cache/
