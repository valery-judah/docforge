DOC_FORGE_ARTIFACT_ROOT=./data
DOC_FORGE_ENVIRONMENT=dev
DOC_FORGE_EMBEDDING_MODEL=transformer
DOC_FORGE_ANSWER_SYNTHESIZER_BACKEND=ollama
DOC_FORGE_ANSWER_SYNTHESIZER_MODEL=qwen3.5:9b
DOC_FORGE_ANSWERING_TOP_K=3
DOC_FORGE_ANSWERING_MIN_SCORE=0.3
DOC_FORGE_ANSWER_SYNTHESIS_TIMEOUT_SECONDS=90
DOC_FORGE_SERVICE_NAME=doc_forge-api

# Transformer embedding runtime. Defaults derive from DOC_FORGE_ARTIFACT_ROOT.
# DOC_FORGE_HF_HOME=./data/huggingface
# DOC_FORGE_TORCHINDUCTOR_CACHE_DIR=./data/torchinductor-cache
# DOC_FORGE_HF_HUB_OFFLINE=false
# DOC_FORGE_TRANSFORMERS_OFFLINE=false

# Answer synthesis runtime.
# For host-local API runs, prefer:
# DOC_FORGE_OLLAMA_BASE_URL=http://127.0.0.1:11434
# For Docker Compose, prefer:
# DOC_FORGE_OLLAMA_BASE_URL=http://host.docker.internal:11434
# To keep tests or offline work self-contained:
# DOC_FORGE_ANSWER_SYNTHESIZER_BACKEND=deterministic

# Optional Compose log run identifier for repo-local JSONL archives.
# DOC_FORGE_LOG_RUN_ID=20260313T120000Z
# DOC_FORGE_JSON_LOG_PATH=./data/logs/compose/manual/api.jsonl

# Separate local observability stack defaults.
# OBSERVABILITY_POSTGRES_DB=doc_forge_observability
# OBSERVABILITY_POSTGRES_USER=doc_forge
# OBSERVABILITY_POSTGRES_PASSWORD=doc_forge
# OBSERVABILITY_POSTGRES_PORT=5433
# OBSERVABILITY_LOKI_PORT=3100
# OBSERVABILITY_GRAFANA_PORT=3000
# DOC_FORGE_OBSERVABILITY_DATABASE_URL=postgresql+psycopg://doc_forge:doc_forge@localhost:5433/doc_forge_observability
