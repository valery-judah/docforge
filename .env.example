DATABASE_URL=postgresql+psycopg://doc-forge:doc-forge@localhost:5432/doc-forge
DOC_FORGE_ARTIFACT_ROOT=./data
DOC_FORGE_ENVIRONMENT=dev
# `make docker-up-build` and docker-backed e2e auto-select host Ollama on Apple
# Silicon when it is reachable. `uv run poe run-api` stays deterministic unless
# you configure these env vars explicitly.
DOC_FORGE_ANSWER_GENERATOR_BACKEND=deterministic
# If you switch to `ollama`, also set a model available in your local Ollama instance.
# DOC_FORGE_ANSWER_GENERATOR_MODEL=llama3.2:1b
# For Docker-backed local runs on Apple Silicon, point containers at host Ollama.
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# Optional Compose log run identifier for repo-local JSONL archives.
# DOC_FORGE_LOG_RUN_ID=20260313T120000Z

# Separate local observability stack defaults.
# OBSERVABILITY_POSTGRES_DB=doc_forge_observability
# OBSERVABILITY_POSTGRES_USER=doc_forge
# OBSERVABILITY_POSTGRES_PASSWORD=doc_forge
# OBSERVABILITY_POSTGRES_PORT=5433
# OBSERVABILITY_LOKI_PORT=3100
# OBSERVABILITY_GRAFANA_PORT=3000
# DOC_FORGE_OBSERVABILITY_DATABASE_URL=postgresql+psycopg://doc_forge:doc_forge@localhost:5433/doc_forge_observability
